# Backend
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:8080

# Supabase (persistência da área de clientes)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Portal de clientes (troque em produção)
CLIENT_PORTAL_USERNAME=cliente
CLIENT_PORTAL_PASSWORD=troque-esta-senha
CLIENT_PORTAL_SESSION_TTL_MS=1800000

# SMTP Configuration (ex: Gmail, Outlook, etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@exemplo.com
SMTP_PASS=sua-senha-ou-app-password

# Destinatário dos contatos
TO_EMAIL=seu-email@exemplo.com
